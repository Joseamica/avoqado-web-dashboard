# ============================================================
# avoqado-web-dashboard — variables de entorno
# ============================================================
# Desarrollador nuevo: copia este archivo a .env
#     cp .env.example .env
#
# Viene pre-configurado para STAGING — seguro de modificar,
# NUNCA toca producción.
#
# Todas las variables VITE_* son PÚBLICAS (terminan en el bundle
# del navegador) — aquí no hay secretos.
# ============================================================

# --- Backend ---
# API del server de STAGING (no producción)
VITE_API_URL=https://avoqado-server-staging.fly.dev
VITE_API_DEV_URL="http://localhost:3000"
VITE_FRONTEND_URL="http://localhost:5173"
# Página de checkout
VITE_CHECKOUT_URL=https://pay.avoqado.io

VITE_STRIPE_PUBLISHABLE_KEY="pk_test_XCv57wYNRXqzP7A5exFgiw4d005M9XPM6X"

VITE_GOOGLE_CLIENT_ID="219752736783-r20hp7rn5aam58o5vn5qr7ij46pqhht8.apps.googleusercontent.com"
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# --- Dev / staging ---
# Salta la verificación de email — cómodo para staging
VITE_SKIP_EMAIL_VERIFICATION=true

# --- Stripe (modo prueba — no mueve dinero real) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_XCv57wYNRXqzP7A5exFgiw4d005M9XPM6X

# --- WhatsApp ---
VITE_WHATSAPP_CENTRAL_NUMBER=+525667976805

# --- Firebase (el dashboard solo lo usa para Storage) ---
VITE_FIREBASE_AUTH_DOMAIN=tu+firebase+proyect
# ⚠️ Jose: copia este valor de tu .env actual (es público, seguro de commitear)
VITE_FIREBASE_API_KEY=

# --- Google (Maps + sign-in — llaves públicas de cliente) ---
